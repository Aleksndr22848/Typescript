    { name: "Смартфон", price: 60000, quantity: 1 },
    { name: "Чехол", price: 2000, quantity: 1 }
  ],
  discount: { kind: "fixed", valueRub: 5000 } // 5000 руб. скидка
};


const orderWithoutDiscount: Order = {
  products: [
    { name: "Книга", price: 500, quantity: 3 }
  ]
};


console.log(calculator.formatOrder(orderWithPercentDiscount));
console.log("\n");
console.log(calculator.formatOrder(orderWithFixedDiscount));
console.log("\n");
console.log(calculator.formatOrder(orderWithoutDiscount));


const edgeCaseOrder: Order = {
