
export type Discount = 
  | { kind: "percent"; value: number }
  | { kind: "fixed"; valueRub: number };

export interface Product {
  name: string;
  price: number;
  quantity: number;
}

export interface Order {
  products: Product[];
  discount?: Discount;
}


import { Discount, Order, Product } from './types';

export class PriceCalculator {
  /**
   * Рассчитывает общую стоимость заказа без скидки
   */
  calculateSubtotal(products: Product[]): number {
    return products.reduce((sum, product) => sum + (product.price * product.quantity), 0);
  }

  applyDiscount(amount: number, discount: Discount): number {
    switch (discount.kind) {
      case "percent":
        const discountAmount = amount * (discount.value / 100);
        return amount - discountAmount;
      
      case "fixed":
        return Math.max(0, amount - discount.valueRub);
      
      default:
        const _exhaustiveCheck: never = discount;
        throw new Error(`Неизвестный тип скидки: ${_exhaustiveCheck}`);
    }
  }
  calculateTotal(order: Order): number {
    const subtotal = this.calculateSubtotal(order.products);
    
    if (order.discount) {
      return this.applyDiscount(subtotal, order.discount);
    }
    
    return subtotal;
  }
  getDiscountDescription(discount: Discount): string {
    switch (discount.kind) {
      case "percent":
        return `${discount.value}% скидка`;
      case "fixed":
        return `${discount.valueRub} руб. скидка`;
      default:
        const _exhaustiveCheck: never = discount;
        return `Неизвестная скидка`;
    }
  }
  formatOrder(order: Order): string {
    const subtotal = this.calculateSubtotal(order.products);
    const total = this.calculateTotal(order);
    
    let result = "=== ДЕТАЛИ ЗАКАЗА ===\n";
    
    order.products.forEach(product => {
      const itemTotal = product.price * product.quantity;
      result += `${product.name}: ${product.price} руб. x ${product.quantity} = ${itemTotal} руб.\n`;
    });
    
    result += `\nПодытог: ${subtotal} руб.`;
    
    if (order.discount) {
      result += `\nСкидка: ${this.getDiscountDescription(order.discount)}`;
    }
    
    result += `\nИТОГО: ${total} руб.`;
    
    return result;
  }
}
import { PriceCalculator } from './calculator';

const calculator = new PriceCalculator();


const orderWithPercentDiscount: Order = {
