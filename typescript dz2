};

console.log("\n=== ГРАНИЧНЫЙ СЛУЧАЙ ===");
console.log(calculator.formatOrder(edgeCaseOrder));


function demonstrateDiscountType(discount: Discount): void {
  console.log(`Тип скидки: ${discount.kind}`);
  
  if (discount.kind === "percent") {
    console.log(`Процент: ${discount.value}%`);
  } else {
    console.log(`Фиксированная сумма: ${discount.valueRub} руб.`);
  }
}

console.log("\n=== ДЕМОНСТРАЦИЯ ТИПОВ СКИДОК ===");
demonstrateDiscountType({ kind: "percent", value: 15 });
demonstrateDiscountType({ kind: "fixed", valueRub: 1000 });
