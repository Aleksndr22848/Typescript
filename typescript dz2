    { name: "Ноутбук", price: 75000, quantity: 1 },
    { name: "Мышь", price: 1500, quantity: 2 },
    { name: "Коврик", price: 800, quantity: 1 }
  ],
  discount: { kind: "percent", value: 10 } // 10% скидка
